unsigned char GetCardEtebarKashan(signed int *Etebar)
{
	*Etebar=CardEtebarKashan;
	
	return(0);
}

//==============================================================================
//==============================================================================
//                              M . I . F . A . R . E
//==============================================================================
//==============================================================================
unsigned int ReadCardIDKashanMifare(unsigned long int *CardID, unsigned int Payment, signed long int *Etebar, signed long int *PreEtebar)
{
unsigned char LogSector=0;
unsigned char LogBlock=0,NewLogBlock=0;
unsigned char DebitSector=0, idx;
unsigned char IssuerSector=0;	
unsigned char MAD[32];
unsigned char buf[16], buf2[16];	
unsigned char Log[16];	
unsigned char ApduCmd[100];
unsigned char ResBuff[256];	
uint8_t pAts[255]; 
unsigned short i, j, RxLength;
unsigned char status;	
uint8_t bCid;
uint8_t bCidEnable; 
uint8_t bNadSupported;
uint8_t bFwi;
uint8_t bFsdi;
uint8_t bFsci;
signed long int li;	
//unsigned int Timeout;
unsigned char WalletType=1;
unsigned char Keys[6]={0xA0, 0xA1, 0xA2, 0xA3, 0xA4, 0xA5};	
unsigned char keyCoded[12];

	
	CardEtebarKashan=0;

  if(ISO14443_SingleTagSelect(buf)) 
		if(ISO14443_SingleTagSelect(buf)) return(4);

  Mf500HostCodeKey(Keys,keyCoded);
  if(ISO14443_Login(0, 0xAA, keyCoded)) return(5);
	//if(ISO14443_LoginE2(0,0x11)) return(5);
  if(ISO14443_ReadBlock(0,buf)) return(6);
  if(ISO14443_ReadBlock(1,MAD)) return(7);
  if(ISO14443_ReadBlock(2,&MAD[16])) return(8);
	
	//=========================================
  GUI_SetColor(0x007FFF00);
  GUI_FillRoundedRect(7+0+5, 275+2, 7+2*70+5, 275+28,0);	//1
  //Select SAM Applet
  ApduCmd[0]=0x00;
  ApduCmd[1]=0xA4;
  ApduCmd[2]=0x04;
  ApduCmd[3]=0x00;
  ApduCmd[4]=0x07;
  ApduCmd[5]=0xD0;
  ApduCmd[6]=0xD1;
  ApduCmd[7]=0xD2;
  ApduCmd[8]=0xD3;
  ApduCmd[9]=0xD4;
  ApduCmd[10]=0xD5;
  ApduCmd[11]=0x01;
  #ifdef DEBUGKASHAN	
  printf("\n\r[SAM]Select Applet :");
  for(i=0; i<12; i++)
    printf("%X ",ApduCmd[i]);
  #endif
	
	//Timeout=OS_TimeMS;	
  RxLength=SAM_SendAPDU_T0(ApduCmd,ResBuff,12,2);
	//printf("\n\r2:%d",OS_TimeMS-Timeout);	
	
	#ifdef DEBUGKASHAN	
  printf("\n\rResponse :");
  for(i=0; i<RxLength; i++)
    printf("%X ",ResBuff[i]);
	#endif	
  if(RxLength < 2) { SAM_RST=0; GUI_Delay(100);	SAM_RST=1; if(RxLength!=2) return(19); else {i=ResBuff[0]; i<<=8; i+=ResBuff[1]; if(i==0) i=19; return(i); } }
	i=ResBuff[0]; i<<=8; i+=ResBuff[1];
  if(i!=0x9000)
	{
		SAM_RST=0; GUI_Delay(100);	SAM_RST=1;
		if(i==0) i=20;
    return(i);		
	}

	//=========================================
  GUI_SetColor(0x001FFF00);
  GUI_FillRoundedRect(7+2*70+2*5, 275+2, 7+3*70+2*5, 275+28,0);	//2
  //Prepare Secure Channel
  ApduCmd[0]=0x80;
  ApduCmd[1]=0xA0;
  ApduCmd[2]=0x02;
  ApduCmd[3]=0x00;
  ApduCmd[4]=0x04;
  ApduCmd[5]=0x31;
  ApduCmd[6]=0x32;
  ApduCmd[7]=0x33;
  ApduCmd[8]=0x34;
  #ifdef DEBUGKASHAN	
  printf("\n\r[SAM]VerifyPIN :");
  for(i=0; i<9; i++)
    printf("%X ",ApduCmd[i]);
  #endif
  RxLength=SAM_SendAPDU_T0(ApduCmd,ResBuff,9,2);
  #ifdef DEBUGKASHAN	
  printf("\n\rResponse :");
  for(i=0; i<RxLength; i++)
    printf("%X ",ResBuff[i]);
	#endif	
  if(RxLength < 2) {	if(RxLength!=2) return(19); else {i=ResBuff[0]; i<<=8; i+=ResBuff[1]; if(i==0) i=19; return(i); } }
	i=ResBuff[0]; i<<=8; i+=ResBuff[1];
  if(i!=0x9000)
	{	
    if(i==0) i=21;
		return(i);		
	}
  
	//=========================================
  GUI_SetColor(0x0007FF00);
  GUI_FillRoundedRect(7+3*70+3*5, 275+2, 7+4*70+3*5, 275+28,0);		//3	
	//Save SAM Challenge
	idx=0;
  ApduCmd[idx++]=0x80;
  ApduCmd[idx++]=0xA6;
  ApduCmd[idx++]=0x20; //index
  ApduCmd[idx++]=0x00;
  ApduCmd[idx++]=0x10;
  for(i=0; i<16; i++)
    ApduCmd[idx++]=buf[i];
  #ifdef DEBUGKASHAN	
  printf("\n\r[SAM]Direct Authentication :");
  for(i=0; i<idx; i++)
    printf("%X ",ApduCmd[i]);
  #endif
  RxLength=SAM_SendAPDU_T0(ApduCmd,ResBuff,idx,2);
  #ifdef DEBUGKASHAN	
  printf("\n\rResponse :");
  for(i=0; i<RxLength; i++)
    printf("%X ",ResBuff[i]);
	#endif	
  if(RxLength < 2) {	if(RxLength!=2) return(19); else {i=ResBuff[0]; i<<=8; i+=ResBuff[1]; if(i==0) i=19; return(i); } }
	i=ResBuff[0]; i<<=8; i+=ResBuff[1];
  if(i!=0x6110)
	{
    if(i==0) i=22;
    return(i);		
	}
	
	//=========================================
  GUI_SetColor(0x0003F800);
  GUI_FillRoundedRect(7+4*70+4*5, 275+2, 7+5*70+4*5, 275+28,0);	//4
	//Save SAM Challenge
  ApduCmd[0]=0x00;
  ApduCmd[1]=0xC0;
  ApduCmd[2]=0x00;
  ApduCmd[3]=0x00;
  ApduCmd[4]=0x10;
  #ifdef DEBUGKASHAN	
  printf("\n\r[SAM]Save DeriveKey :");
  for(i=0; i<5; i++)
    printf("%X ",ApduCmd[i]);
  #endif
  RxLength=SAM_SendAPDU_T0(ApduCmd,ResBuff,5,18);
  #ifdef DEBUGKASHAN	
  printf("\n\rResponse :");
  for(i=0; i<RxLength; i++)
    printf("%X ",ResBuff[i]);
	#endif	
  if(RxLength < 18) {	if(RxLength!=2) return(19); else {i=ResBuff[0]; i<<=8; i+=ResBuff[1]; if(i==0) i=19; return(i); } }
	i=ResBuff[16]; i<<=8; i+=ResBuff[17];
  if(i!=0x9000)
	{
    if(i==0) i=22;
    return(i);		
	}
		
  #ifdef DEBUGKASHAN	
  printf("\n\r[MAD] : ");
	for(i=0; i<32; i++)
	  printf("%X ", MAD[i]);
  #endif
	idx=2;
	for(i=1; i<=15; i++)
	{
		j=MAD[idx]; j<<=8; j+=MAD[idx+1];
		if(j==0x88DE)
			DebitSector=i;
		if(j==0x8810) 
			LogSector=i;
		if(j==0x00FA)
			IssuerSector=i;
		idx+=2;
	}
	
	if((DebitSector==0)||(LogSector==0)||(IssuerSector==0))
	{
    #ifdef DEBUGKASHAN	
    printf("\n\rError, Debit AID not found");
    #endif
		return(9);
	}
	
  if(ISO14443_Login(IssuerSector, 0xAA, keyCoded)) return(5);
  if(ISO14443_ReadBlock(IssuerSector*4,buf2)) return(6);
  #ifdef DEBUGKASHAN	
  printf("\n\r[Issuer] %d:",IssuerSector);
  for(i=0; i<16; i++)
    printf("%X ",buf2[i]);
  #endif
	PayInfo[0]='K'; //Kashan
  for(i=0; i<8; i++)
		PayInfo[i+7]=buf2[i+6];

  PayInfo[1]=buf2[0]; //Version
  PayInfo[2]=buf2[1]; //Version
	
  #ifdef DEBUGKASHAN	
  printf("\n\r[Login Debit] %d:",DebitSector);
  #endif
	for(i=0; i<6; i++)
	  Keys[i]=ResBuff[i];
  Mf500HostCodeKey(Keys,keyCoded);
  if(ISO14443_Login(DebitSector, 0xAA, keyCoded)) return(10);
  if(ISO14443_ReadBlock(DebitSector*4,Log)) return(11);
  #ifdef DEBUGKASHAN	
  printf("\n\rRead Debit :");
  for(i=0; i<16; i++)
    printf("%X ",buf[i]);
  #endif
  if(ISO14443_ReadValueBlock((DebitSector*4)+1,&li)) return(12);
  #ifdef DEBUGKASHAN	
  printf("\n\rRead City Block : %ld", li);
  #endif

	if(Payment>li) 
  {
    if(ISO14443_ReadValueBlock((DebitSector*4)+2,&li)) return(12);
    #ifdef DEBUGKASHAN	
    printf("\n\rRead Cash Block : %ld", li);
    #endif
    
    if(Payment>li) 
      return(0x9930); //Etebar Kam Ast
    WalletType=2;
  }	
	
	*PreEtebar=li;
	*Etebar=li-Payment;
	
	
  for(i=0; i<12; i++)	
	  buf[i]=Log[i];
	buf[12]=(li>>24)&0xFF;
	buf[13]=(li>>16)&0xFF;
	buf[14]=(li>>8)&0xFF;
	buf[15]=li&0xFF;

	LogBlock=Log[12];
	if(++LogBlock>10) LogBlock=0;
	if((LogBlock==3)||(LogBlock==7)) //sector trailer
		LogBlock++;
	NewLogBlock=LogBlock;
	LogBlock=(LogSector*4)+LogBlock;
	LogSector=LogBlock/4;
  #ifdef DEBUGKASHAN	
	printf("\n\rLogSector: %d LogBlock: %d",LogSector,LogBlock);
  #endif
	
  if(ISO14443_Login(LogSector, 0xAA, keyCoded)) 
	{ 
    #ifdef DEBUGKASHAN	
		printf("\n\rError loing to %d", LogSector);
		#endif
		return(5);
	}
  if(ISO14443_WriteBlock(LogBlock,buf)) 
	{ 
    #ifdef DEBUGKASHAN	
		printf("\n\rError write to %d", LogBlock);
		#endif
		return(5);
	}

	Log[0]=_BCD(Config.TerminalID[0]*10+Config.TerminalID[1]);
	Log[1]=_BCD(Config.TerminalID[2]*10+Config.TerminalID[3]);
	Log[2]=_BCD(Config.TerminalID[4]*10+Config.TerminalID[5]);
	Log[3]=_BCD(Config.TerminalID[6]*10+Config.TerminalID[7]);

  jalali_to_gregorian(Year,Month,Day,&CurrentDate);
  MYear=CurrentDate.year;
  MMonth=CurrentDate.month;
  MDay=CurrentDate.day;

	Log[4]=(MYear%100);
	Log[4]<<=1;
	Log[4]|=((MMonth&0x0F)>>3);
	Log[5]=MMonth&0x07; 
	Log[5]<<=5;
	Log[5]|=(MDay&0x1F);
	Log[6]=Hour;
	Log[6]<<=3;
	Log[6]|=((Min&0x3F)>>3);
	Log[7]=Min;
	Log[7]<<=5;
	Log[7]|=((Sec>>1)&0x1F);
	
	Log[8]=1; //debit
	Log[9]=WalletType; //1 city  2 cash
	i=Log[10]; i<<=8;
	i+=Log[11];
	i++; //TxCounter
	Log[10]=(i>>8)&0xFF;
	Log[11]=i&0xFF;
	Log[12]=NewLogBlock;
  PayInfo[15]=WalletType;
	PayInfo[16]=Log[10];
	PayInfo[17]=Log[11];
	
  #ifdef DEBUGKASHAN	
	printf("\n\rLog:");
	for(i=0; i<16; i++)
    printf("%X ",Log[i]);
	#endif	

  if(ISO14443_Login(DebitSector, 0xAA, keyCoded)) 
	{
    #ifdef DEBUGKASHAN	
		printf("\n\r2)Error loing to %d", DebitSector);
		#endif
		return(5);
	}
  if(ISO14443_WriteBlock(DebitSector*4,Log)) 
	{ 
    #ifdef DEBUGKASHAN	
		printf("\n\r2)Error write to %d", DebitSector*4);
		#endif
		return(5);
	}

  GUI_SetColor(GUI_GREEN);
  GUI_FillRoundedRect(7+5*70+5*5, 275+2, 7+6*70+5*5, 275+28,0);//5
	
  #ifdef DEBUGKASHAN	
  printf("\n\r[Debit] : ");
  #endif
  if(WalletType==1)
  {
    if(ISO14443_Decrement((DebitSector*4)+1,Payment)) return(13);
  }else{
    if(ISO14443_Decrement((DebitSector*4)+2,Payment)) return(13);
  }
  #ifdef DEBUGKASHAN	
  printf("OK");
  #endif

  #ifdef DEBUGKASHAN	
	printf("\n\PayInfo:");
	for(i=0; i<32; i++)
    printf("%X ",PayInfo[i]);
	#endif	

	
	return(0);
}

#endif