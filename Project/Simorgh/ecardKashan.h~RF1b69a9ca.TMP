	LastTransactionKashan.Payment=Price;
*/
  //MM  

	
 //==============================================================================
  //Read Log
  ApduCmd[0]=0xA0;
  ApduCmd[1]=0x10;
  ApduCmd[2]=0x00;
  ApduCmd[3]=0x00;
  ApduCmd[4]=0xFF;


        
   // GetTimeStamp();    printf("\n\rTime66=%d ",timestamp+1);
