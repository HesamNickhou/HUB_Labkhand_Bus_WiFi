    printf("%X ",ApduCmd[i]);
  #endif
  
  				
  #ifndef WithPN532
  SendAPDU(ApduCmd, 11, ResBuff, &RxLength);			
  #else
  NFC_SendAPDU(ApduCmd, 11, ResBuff, &RxLength);
  #endif   

#ifdef DEBUGKASHAN	
      SetTX485();
