 //==============================================================================
  //Debit
  ApduCmd[0]=0xA0;
  ApduCmd[1]=0xAF;
  ApduCmd[2]=0x00;
  ApduCmd[3]=0x00;
  ApduCmd[4]=0x06;
  ApduCmd[5]=0x06;

  ApduCmd[6]=0x0;
  ApduCmd[7]=0x0;
  ApduCmd[8]=(Payment>>8) & 0xFF;
  ApduCmd[9]=Payment & 0xFF;
	
	ApduCmd[10]=CRC8(ApduCmd, 5, 5);
        
        // GetTimeStamp();    printf("\n\rTime66=%d ",timestamp+1);
  #ifdef DEBUGKASHAN	
            SetTX485();
  printf("\n\r[CARD]Debit :");
